<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="pkg.vms.controller.VouchersController">

    <!-- HEADER -->
    <top>
        <HBox spacing="15" style="-fx-background-color:#1e1e1e;">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Label text="Vouchers Management"
                   style="-fx-text-fill:white; -fx-font-size:20px; -fx-font-weight:bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="searchHeaderField"
                       promptText="Search voucher..."
                       prefWidth="250"/>

            <Button text="Search" onAction="#handleSearch"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- TOP ACTION BAR -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Generate Vouchers" fx:id="generateButton" onAction="#handleGenerate"/>
                <Button text="+ Add Voucher" fx:id="addButton" onAction="#handleAddVoucher"/>
            </HBox>
            <Separator/>

            <!-- VOUCHERS TABLE -->
            <TableView fx:id="voucherTable" prefHeight="300">
                <columns>
                    <TableColumn fx:id="codeColumn" text="Code" prefWidth="150"/>
                    <TableColumn fx:id="priceColumn" text="Price" prefWidth="120"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="140"/>
                    <TableColumn fx:id="initDateColumn" text="Init Date" prefWidth="150"/>
                    <TableColumn fx:id="expiryDateColumn" text="Expiry Date" prefWidth="150"/>
                </columns>
            </TableView>

            <!-- TABLE ACTION BUTTONS -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="5" right="0" bottom="5" left="0"/>
                </padding>
                <Button text="Edit" fx:id="editButton" onAction="#handleEditVoucher"/>
                <Button text="Delete" fx:id="deleteButton" onAction="#handleDeleteVoucher"/>
            </HBox>
            <Separator/>

            <!-- ADD / EDIT VOUCHER FORM (optional, hidden by default) -->
            <VBox fx:id="addForm" spacing="12" visible="false" managed="false"
                  style="-fx-background-color:#2d2d2d; -fx-padding:20; -fx-background-radius:10;">

                <Label fx:id="formTitle"
                       text="Add/Edit Voucher"
                       style="-fx-text-fill:white; -fx-font-size:18px; -fx-font-weight:bold;"/>

                <TextField fx:id="formCode" promptText="Voucher Code"/>
                <TextField fx:id="formPrice" promptText="Price"/>
                <TextField fx:id="formStatus" promptText="Status"/>
                <DatePicker fx:id="formInitDate" promptText="Init Date"/>
                <DatePicker fx:id="formExpiryDate" promptText="Expiry Date"/>

                <Label fx:id="formError" style="-fx-text-fill:red;"/>

                <HBox spacing="10">
                    <Button text="Save" onAction="#handleFormSave"/>
                    <Button text="Cancel" onAction="#handleCancel"/>
                </HBox>
            </VBox>

        </VBox>
    </center>

</BorderPane>
