<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="pkg.vms.controller.BranchController"
            stylesheets="@../css/branches.css">
    <!-- HEADER -->
    <top>
        <HBox spacing="15" styleClass="branches-header" alignment="CENTER_LEFT">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Label text="Branches Management"
                   styleClass="header-title-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchHeaderField"
                       promptText="Search branch..."
                       prefWidth="250"
                       styleClass="search-field"/>
            <Button text="Search" onAction="#handleSearch" styleClass="search-button"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20" styleClass="content-container">
            <!-- Filter and Add Company Section -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Filter by Company:" 
                       style="-fx-font-size: 14px; -fx-text-fill: #003049; -fx-font-weight: bold;"/>
                <ComboBox fx:id="companyFilterCombo" 
                         promptText="All Companies"
                         prefWidth="200"
                         styleClass="filter-combo"
                         onAction="#handleCompanyFilter"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="addCompanyButton" text="+ Add New Company" 
                       onAction="#handleAddCompany" 
                       styleClass="add-company-button"/>
                <Button text="+ Add New Branch" 
                       onAction="#handleAddBranch" 
                       styleClass="add-company-button"/>
            </HBox>
            
            <Separator styleClass="separator"/>

            <!-- Branches Table -->
            <VBox styleClass="branches-table">
                <TableView fx:id="branchTable" prefHeight="300">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="companyColumn" text="Company" prefWidth="180"/>
                        <TableColumn fx:id="industryColumn" text="Industry" prefWidth="150"/>
                        <TableColumn fx:id="locationColumn" text="Location" prefWidth="200"/>
                        <TableColumn fx:id="responsibleColumn" text="Responsible User" prefWidth="180"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Action buttons under table -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="5" right="0" bottom="5" left="0"/>
                </padding>
                <Button text="View Details" onAction="#handleViewDetails" styleClass="action-button"/>
                <Button text="Edit" onAction="#handleEdit" styleClass="action-button"/>
                <Button text="Delete" onAction="#handleDelete" styleClass="action-button"/>
                <Button text="Delete Company" 
                       onAction="#handleDeleteCompany" 
                       styleClass="action-button"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Export Excel" onAction="#handleExportExcel" styleClass="export-button"/>
            </HBox>

            <Separator styleClass="separator"/>

            <!-- Branch Details Panel -->
            <VBox fx:id="detailsPane"
                  spacing="10"
                  visible="false"
                  managed="false"
                  styleClass="branch-details-panel">
                <Label fx:id="detailsTitle"
                       styleClass="details-title"/>

                <!-- Info grid -->
                <GridPane hgap="15" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="100" halignment="LEFT"/>
                        <ColumnConstraints hgrow="ALWAYS" halignment="LEFT"/>
                    </columnConstraints>

                    <rowConstraints>
                        <RowConstraints minHeight="22" prefHeight="22"/>
                        <RowConstraints minHeight="22" prefHeight="22"/>
                        <RowConstraints minHeight="22" prefHeight="22"/>
                        <RowConstraints minHeight="22" prefHeight="22"/>
                        <RowConstraints minHeight="22" prefHeight="22"/>
                        <RowConstraints minHeight="22" prefHeight="22"/>
                    </rowConstraints>

                    <Label text="Branch ID:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="details-label"/>
                    <Label fx:id="detId" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="details-value"/>

                    <Label text="Company:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="details-label"/>
                    <Label fx:id="detCompany" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="details-value"/>

                    <Label text="Industry:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="details-label"/>
                    <Label fx:id="detIndustry" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="details-value"/>

                    <Label text="Location:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="details-label"/>
                    <Label fx:id="detLocation" GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="details-value"/>

                    <Label text="Phone:" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="details-label"/>
                    <Label fx:id="detPhone" GridPane.rowIndex="4" GridPane.columnIndex="1" styleClass="details-value"/>

                    <Label text="Responsible User:" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="details-label"/>
                    <Label fx:id="detResponsible" GridPane.rowIndex="5" GridPane.columnIndex="1" styleClass="details-value"/>
                </GridPane>
            </VBox>

            <!-- ADD / EDIT BRANCH FORM (initially hidden) -->
            <ScrollPane fitToWidth="true" 
                       pannable="true"
                       vbarPolicy="AS_NEEDED"
                       hbarPolicy="NEVER"
                       visible="false"
                       managed="false"
                       fx:id="addFormScrollPane"
                       prefHeight="350"
                       maxHeight="400"
                       styleClass="form-scroll-pane">
                <VBox fx:id="addForm"
                      spacing="10"
                      styleClass="branch-form">
                    <Label fx:id="formTitle"
                           text="Add New Branch"
                           styleClass="form-title"/>

                    <GridPane hgap="15" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="130" prefWidth="130"/>
                            <ColumnConstraints minWidth="250" prefWidth="250" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <rowConstraints>
                            <RowConstraints minHeight="32" prefHeight="32"/>
                            <RowConstraints minHeight="32" prefHeight="32"/>
                            <RowConstraints minHeight="32" prefHeight="32"/>
                            <RowConstraints minHeight="32" prefHeight="32"/>
                            <RowConstraints minHeight="32" prefHeight="32"/>
                        </rowConstraints>

                        <Label text="Company:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="details-label"/>
                        <ComboBox fx:id="addCompanyCombo" promptText="Select Company" 
                                 styleClass="form-combo-box"
                                 prefWidth="250"
                                 GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Location:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="details-label"/>
                        <TextField fx:id="addLocation" promptText="Enter location" 
                                  styleClass="form-text-field"
                                  GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Phone:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="details-label"/>
                        <TextField fx:id="addPhone" promptText="Enter phone number" 
                                  styleClass="form-text-field"
                                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Responsible User:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="details-label"/>
                        <ComboBox fx:id="addResponsibleCombo" promptText="Select user" 
                                 styleClass="form-combo-box"
                                 prefWidth="250"
                                 onAction="#handleUserSelection"
                                 GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="User Email:" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="details-label"/>
                        <TextField fx:id="addUserEmail" promptText="Email will auto-populate" 
                                  styleClass="form-text-field"
                                  editable="false"
                                  GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    </GridPane>

                    <Label fx:id="addError" styleClass="form-error"/>

                    <HBox spacing="10">
                        <Button fx:id="formSaveButton" text="Save" onAction="#handleFormSave" styleClass="form-save-button"/>
                        <Button text="Cancel" onAction="#handleAddCancel" styleClass="form-cancel-button"/>
                    </HBox>
                </VBox>
            </ScrollPane>

            <!-- ADD COMPANY FORM (initially hidden) -->
            <VBox fx:id="addCompanyForm"
                  spacing="10"
                  visible="false"
                  managed="false"
                  styleClass="branch-form">
                    <Label text="Add New Company"
                           styleClass="form-title"/>

                    <GridPane hgap="15" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="130" prefWidth="130"/>
                            <ColumnConstraints minWidth="250" prefWidth="250" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <rowConstraints>
                            <RowConstraints minHeight="32" prefHeight="32"/>
                            <RowConstraints minHeight="32" prefHeight="32"/>
                        </rowConstraints>

                        <Label text="Company Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="details-label"/>
                        <TextField fx:id="addCompanyName" promptText="Enter company name" 
                                  styleClass="form-text-field"
                                  GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Industry:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="details-label"/>
                        <TextField fx:id="addCompanyIndustry" promptText="Enter industry" 
                                  styleClass="form-text-field"
                                  GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    </GridPane>

                    <Label fx:id="companyError" styleClass="form-error"/>

                    <HBox spacing="10">
                        <Button text="Save" onAction="#handleCompanySave" styleClass="form-save-button"/>
                        <Button text="Cancel" onAction="#handleCompanyCancel" styleClass="form-cancel-button"/>
                    </HBox>
            </VBox>

            <!-- DELETE COMPANY FORM (initially hidden) -->
            <VBox fx:id="deleteCompanyForm"
                  spacing="10"
                  visible="false"
                  managed="false"
                  styleClass="branch-form">
                <Label text="Delete Company"
                       styleClass="form-title"/>

                <Label fx:id="deleteCompanyInfo" 
                       style="-fx-font-size: 12px; -fx-text-fill: #003049; -fx-wrap-text: true;"/>

                <Label fx:id="deleteCompanyBranches" 
                       style="-fx-font-size: 12px; -fx-text-fill: #c1121f; -fx-font-weight: bold; -fx-wrap-text: true;"/>

                <Label fx:id="deleteCompanyError" styleClass="form-error"/>

                <HBox spacing="10">
                    <Button text="Confirm Delete" onAction="#handleConfirmDeleteCompany" styleClass="form-save-button"/>
                    <Button text="Cancel" onAction="#handleCancelDeleteCompany" styleClass="form-cancel-button"/>
                </HBox>
            </VBox>

        </VBox>
    </center>
</BorderPane>

